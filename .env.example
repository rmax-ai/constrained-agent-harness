# CAH Configuration
# Copy to .env and fill in your values.

# Model configuration
CAH_MODEL=gemini-3.5-flash

# Google AI API key (use one of these two methods)
CAH_GOOGLE_API_KEY=
# OR Vertex AI credentials
# CAH_USE_VERTEX_AI=true
# CAH_GOOGLE_CLOUD_PROJECT=
# CAH_GOOGLE_CLOUD_LOCATION=

# Runtime paths
CAH_RUNTIME_DIR=.cah
CAH_DATABASE_URL=sqlite:///.cah/cah.db

# Logging
CAH_LOG_LEVEL=INFO
